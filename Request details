  <!-- ░░ COLUMNA PRINCIPAL ░░ -->
  <div style="flex:1;display:flex;flex-direction:column;min-width:0;">

    <!-- TOPBAR (chrome heredado) -->
    <div style="height:60px;background:#fff;box-shadow:0 4px 5px rgba(0,0,0,.12);display:flex;align-items:center;justify-content:flex-end;padding:0 24px;gap:12px;flex-shrink:0;z-index:5;">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" style="cursor:pointer;"><circle cx="14" cy="14" r="13.5" stroke="#1755A1"/><path d="M12.33 20.11V15.94H15.66V20.11C15.66 20.56 16.04 20.94 16.5 20.94H19C19.46 20.94 19.83 20.56 19.83 20.11V14.27H21.25C21.63 14.27 21.81 13.8 21.52 13.55L14.56 7.27C14.24 6.99 13.76 6.99 13.44 7.27L6.47 13.55C6.19 13.8 6.36 14.27 6.75 14.27H8.16V20.11C8.16 20.56 8.54 20.94 9 20.94H11.5C11.96 20.94 12.33 20.56 12.33 20.11Z" fill="#1755A1"/></svg>
      <div style="padding:4px 6px;background:#fff;border-radius:14px;outline:1px #1755A1 solid;display:inline-flex;align-items:center;gap:8px;cursor:pointer;"><div style="width:20px;height:20px;border-radius:50%;overflow:hidden;flex-shrink:0;"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><g clip-path="url(#fl)"><path fill-rule="evenodd" d="M0 0L10 10L0 20V0ZM20 0L10 10L20 20V0Z" fill="#000001"/><path fill-rule="evenodd" d="M0 0L10 10L20 0H0ZM0 20L10 10L20 20H0Z" fill="#009900"/><path fill-rule="evenodd" d="M20 0H18.14L0 18.14V20H1.86L20 1.86V0Z" fill="#FFCC00"/><path fill-rule="evenodd" d="M0 0V1.86L18.14 20H20V18.14L1.86 0H0Z" fill="#FFCC00"/></g><defs><clipPath id="fl"><rect width="20" height="20" rx="10" fill="white"/></clipPath></defs></svg></div><span style="color:#1755A1;font-size:11px;">Jamaica</span><svg width="7" height="4" viewBox="0 0 7 4" fill="none"><path d="M0 0L3.5 3.5L7 0H0Z" fill="#1755A1"/></svg></div>
      <div style="padding:4px 18px;background:#fff;border-radius:14px;outline:1px #1755A1 solid;display:inline-flex;align-items:center;gap:18px;cursor:pointer;"><span style="color:#1755A1;font-size:11px;">Log out</span><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" stroke="#1755A1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
    </div>

    <!-- MAIN -->
    <div style="flex:1;overflow:auto;padding:16px 22px 36px;">

      <!-- BARRA DE ACCIÓN -->
      <div style="display:flex;align-items:center;gap:14px;margin-bottom:16px;">
        <button onClick="{{ goBack }}" style="display:flex;align-items:center;gap:5px;background:none;border:none;color:#1F2D3D;font-size:14px;text-decoration:underline;cursor:pointer;font-family:'Montserrat',sans-serif;"><svg width="8" height="12" viewBox="0 0 8 12" fill="none"><path d="M7 1L1 6l6 5" stroke="#1F2D3D" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>Return</button>
        <div style="display:flex;align-items:center;gap:7px;background:#E7C240;border-radius:15px;padding:5px 15px;color:#fff;font-size:11px;font-weight:500;"><svg width="15" height="15" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" stroke="white" stroke-width="1.5"/><path d="M10 6V11M10 13.5V14" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>Request pending</div>
        <div style="flex:1;"></div>
        <button style="border:1px solid #21345E;border-radius:15px;padding:7px 17px;color:#21345E;font-size:11px;background:#fff;cursor:pointer;font-family:'Montserrat',sans-serif;">Telephone verification</button>
        <div style="position:relative;">
          <button onClick="{{ toggleDoc }}" style="border:1px solid #21345E;border-radius:15px;padding:7px 17px;color:#21345E;font-size:11px;background:#fff;cursor:pointer;display:flex;align-items:center;gap:9px;font-family:'Montserrat',sans-serif;">Documentation<svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="#21345E" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
          <sc-if value="{{ docMenu }}" hint-placeholder-val="{{ false }}">
            <div style="position:absolute;right:0;top:38px;background:#fff;border:1px solid #E1E4E8;border-radius:10px;box-shadow:0 8px 24px rgba(0,0,0,.14);width:190px;overflow:hidden;z-index:20;">
              <div style="padding:11px 16px;font-size:12px;color:#1F2D3D;cursor:pointer;border-bottom:1px solid #EDEEF1;">View documents</div>
              <div style="padding:11px 16px;font-size:12px;color:#1F2D3D;cursor:pointer;">Upload document</div>
            </div>
          </sc-if>
        </div>
      </div>

      <!-- 3 HEADER CARDS (layout heredado, data nueva) -->
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:16px;">
        <!-- Card 1: identidad -->
        <div style="background:#fff;border-radius:10px;border:1px solid #1755A1;padding:16px 20px;">
          <div style="display:flex;align-items:baseline;gap:8px;padding:11px 0;border-bottom:1px solid #E8E8F4;"><span style="font-size:12px;font-weight:600;color:#000;min-width:128px;">Customer name:</span><span style="font-size:12px;color:#000;">Marc-Waine Jordon Williams</span></div>
          <div style="display:flex;align-items:baseline;gap:8px;padding:11px 0;border-bottom:1px solid #E8E8F4;"><span style="font-size:12px;font-weight:600;color:#000;min-width:128px;">Document number:</span><span style="font-size:12px;color:#000;">123510660</span></div>
          <div style="display:flex;align-items:baseline;gap:8px;padding:11px 0;"><span style="font-size:12px;font-weight:600;color:#000;min-width:128px;">Customer type:</span><span style="font-size:12px;color:#000;">Recurrent</span></div>
        </div>
        <!-- Card 2: producto / riesgo -->
        <div style="background:#fff;border-radius:10px;border:1px solid #1755A1;padding:16px 20px;">
          <div style="display:flex;align-items:baseline;gap:8px;padding:11px 0;border-bottom:1px solid #E8E8F4;"><span style="font-size:12px;font-weight:600;color:#000;min-width:104px;">Product type:</span><span style="font-size:12px;color:#000;">HP + Consumer Line</span></div>
          <div style="display:flex;align-items:baseline;gap:8px;padding:11px 0;border-bottom:1px solid #E8E8F4;"><span style="font-size:12px;font-weight:600;color:#000;min-width:104px;">Scoring:</span><span style="font-size:12px;color:#000;">789</span></div>
          <div style="display:flex;align-items:baseline;gap:8px;padding:11px 0;"><span style="font-size:12px;font-weight:600;color:#000;min-width:104px;">Classification:</span><span style="font-size:12px;color:#000;">N</span></div>
        </div>
        <!-- Card 3: origen de la solicitud -->
        <div style="background:#fff;border-radius:10px;border:1px solid #1755A1;padding:16px 20px;">
          <div style="display:flex;align-items:baseline;gap:8px;padding:11px 0;border-bottom:1px solid #E8E8F4;"><span style="font-size:12px;font-weight:600;color:#000;min-width:118px;">Request number:</span><span style="font-size:12px;color:#000;">279600</span></div>
          <div style="display:flex;align-items:baseline;gap:8px;padding:11px 0;border-bottom:1px solid #E8E8F4;"><span style="font-size:12px;font-weight:600;color:#000;min-width:118px;">Seller:</span><span style="font-size:12px;color:#000;">Tiffany Dunbar</span></div>
          <div style="display:flex;align-items:baseline;gap:8px;padding:11px 0;"><span style="font-size:12px;font-weight:600;color:#000;min-width:118px;">Store:</span><span style="font-size:12px;color:#000;">LKD JM Half Way Tree</span></div>
        </div>
      </div>

      <!-- FRANJA DE KPIs -->
      <div style="display:flex;background:#fff;border:1px solid #E6E8EC;border-radius:10px;padding:16px 0;margin-bottom:18px;">
        <div style="flex:1;padding:0 22px;">
          <div style="font-size:10px;font-weight:600;letter-spacing:.6px;color:#7A8189;margin-bottom:7px;">TOTAL ARREARS</div>
          <div style="font-size:23px;font-weight:700;color:#C0341F;line-height:1;">J$&nbsp;24,310</div>
          <div style="font-size:11px;color:#7A8189;margin-top:6px;">2 accounts · in arrears</div>
        </div>
        <div style="flex:1;padding:0 22px;border-left:1px solid #E6E8EC;">
          <div style="font-size:10px;font-weight:600;letter-spacing:.6px;color:#7A8189;margin-bottom:7px;">MONTHLY INSTALLMENT</div>
          <div style="font-size:23px;font-weight:700;color:#1C3A66;line-height:1;">J$&nbsp;38,120</div>
          <div style="font-size:11px;color:#7A8189;margin-top:6px;">Available amount</div>
        </div>
        <div style="flex:1;padding:0 22px;border-left:1px solid #E6E8EC;">
          <div style="font-size:10px;font-weight:600;letter-spacing:.6px;color:#7A8189;margin-bottom:7px;">DSR</div>
          <div style="font-size:23px;font-weight:700;color:#1C3A66;line-height:1;">41%</div>
          <div style="font-size:11px;color:#7A8189;margin-top:6px;">Installment / income</div>
        </div>
        <div style="flex:1.25;padding:0 22px;border-left:1px solid #E6E8EC;">
          <div style="font-size:10px;font-weight:600;letter-spacing:.6px;color:#7A8189;margin-bottom:7px;">CASH LOAN AVAILABLE</div>
          <div style="font-size:23px;font-weight:700;color:#1C3A66;line-height:1;">J$&nbsp;180,000</div>
          <div style="font-size:11px;color:#7A8189;margin-top:6px;">of J$ 220,000</div>
        </div>
        <div style="flex:1.25;padding:0 22px;border-left:1px solid #E6E8EC;">
          <div style="font-size:10px;font-weight:600;letter-spacing:.6px;color:#7A8189;margin-bottom:7px;">HIRED PURCHASES AVAILABLE</div>
          <div style="font-size:23px;font-weight:700;color:#1C3A66;line-height:1;">J$&nbsp;95,000</div>
          <div style="font-size:11px;color:#7A8189;margin-top:6px;">of J$ 150,000</div>
        </div>
      </div>

      <!-- TABS -->
      <div style="display:flex;border-radius:8px 8px 0 0;overflow:hidden;">
        <div onClick="{{ setTab0 }}" style="flex:1;text-align:center;padding:15px;font-size:15px;font-weight:600;color:#fff;cursor:pointer;background: {{ tab0bg }};border-bottom:3px solid {{ tab0ac }};">Customer</div>
        <div onClick="{{ setTab1 }}" style="flex:1;text-align:center;padding:15px;font-size:15px;font-weight:600;color:#fff;cursor:pointer;background: {{ tab1bg }};border-bottom:3px solid {{ tab1ac }};">AML</div>
        <div onClick="{{ setTab2 }}" style="flex:1;text-align:center;padding:15px;font-size:15px;font-weight:600;color:#fff;cursor:pointer;background: {{ tab2bg }};border-bottom:3px solid {{ tab2ac }};">Resolution</div>
      </div>

      <!-- CONTENIDO -->
      <div style="background:#fff;border-radius:0 0 10px 10px;box-shadow:0 2px 10px rgba(0,0,0,.06);">

        <!-- ══ TAB CUSTOMER ══ -->
        <sc-if value="{{ isCustomer }}" hint-placeholder-val="{{ true }}">
          <div style="padding:26px 32px 30px;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:28px;">
              <!-- General information -->
              <div style="background:#fff;border:1px solid #E6E8EC;border-radius:16px;padding:22px 26px;">
                <div style="font-size:16px;font-weight:700;color:#1F2D3D;margin-bottom:6px;">General information</div>
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:var(--fy,14px) 0;border-bottom:1px solid #EDEEF1;"><span style="font-size:14px;color:#7A8189;flex-shrink:0;">Full name</span><span style="font-size:14px;font-weight:600;color:#1F2D3D;text-align:right;">Marc-Waine Jordon Williams</span></div>
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:var(--fy,14px) 0;border-bottom:1px solid #EDEEF1;"><span style="font-size:14px;color:#7A8189;flex-shrink:0;">Document number (TRN)</span><span style="font-size:14px;font-weight:600;color:#1F2D3D;text-align:right;">123510660</span></div>
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:var(--fy,14px) 0;border-bottom:1px solid #EDEEF1;"><span style="font-size:14px;color:#7A8189;flex-shrink:0;">Birth date</span><span style="font-size:14px;font-weight:600;color:#1F2D3D;text-align:right;">27/09/1993</span></div>
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:var(--fy,14px) 0;border-bottom:1px solid #EDEEF1;"><span style="font-size:14px;color:#7A8189;flex-shrink:0;">Gender</span><span style="font-size:14px;font-weight:600;color:#1F2D3D;text-align:right;">Male</span></div>
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:var(--fy,14px) 0;border-bottom:1px solid #EDEEF1;"><span style="font-size:14px;color:#7A8189;flex-shrink:0;">Marital status</span><span style="font-size:14px;font-weight:600;color:#1F2D3D;text-align:right;">Other</span></div>
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:var(--fy,14px) 0;border-bottom:1px solid #EDEEF1;"><span style="font-size:14px;color:#7A8189;flex-shrink:0;">Dependents</span><span style="font-size:14px;font-weight:600;color:#1F2D3D;text-align:right;">0</span></div>
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:var(--fy,14px) 0;border-bottom:1px solid #EDEEF1;"><span style="font-size:14px;color:#7A8189;flex-shrink:0;">Nationality</span><span style="font-size:14px;font-weight:600;color:#1F2D3D;text-align:right;">Jamaican</span></div>
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:var(--fy,14px) 0;"><span style="font-size:14px;color:#7A8189;flex-shrink:0;">Email</span><span style="font-size:14px;font-weight:600;color:#1F2D3D;text-align:right;">marcwainewilliams@gmail.com</span></div>
              </div>
              <!-- Financial information -->
              <div style="background:#fff;border:1px solid #E6E8EC;border-radius:16px;padding:22px 26px;">
                <div style="font-size:16px;font-weight:700;color:#1F2D3D;margin-bottom:6px;">Financial information</div>
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:var(--fy,14px) 0;border-bottom:1px solid #EDEEF1;"><span style="font-size:14px;color:#7A8189;flex-shrink:0;">Workplace</span><span style="font-size:14px;font-weight:600;color:#1F2D3D;text-align:right;">Courts Administration Division</span></div>
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:var(--fy,14px) 0;border-bottom:1px solid #EDEEF1;"><span style="font-size:14px;color:#7A8189;flex-shrink:0;">Position</span><span style="font-size:14px;font-weight:600;color:#1F2D3D;text-align:right;">Other</span></div>
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:var(--fy,14px) 0;border-bottom:1px solid #EDEEF1;"><span style="font-size:14px;color:#7A8189;flex-shrink:0;">Source of income</span><span style="font-size:14px;font-weight:600;color:#1F2D3D;text-align:right;">Salary</span></div>
                <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;padding:var(--fy,14px) 0;border-bottom:1px solid #EDEEF1;"><span style="font-size:14px;color:#7A8189;flex-shrink:0;">Frequency of pay</span><span style="font-size:14px;font-weight:600;color:#1F2D3D;text-align:right;">Monthly</span></div>
