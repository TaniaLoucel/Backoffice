                <div style="border-bottom:1px solid #1C3A66;padding-bottom:7px;"><div style="font-size:11px;color:#1C3A66;margin-bottom:7px;">Observations</div><input onInput="{{ onObs }}" placeholder="..." style="border:none;outline:none;background:transparent;font-family:'Montserrat',sans-serif;font-size:14px;font-weight:600;color:#1C3A66;width:100%;"></div>
              </div>
              <div style="display:flex;align-items:center;justify-content:flex-end;gap:16px;">
                <sc-if value="{{ saved }}" hint-placeholder-val="{{ false }}">
                  <span style="display:flex;align-items:center;gap:7px;font-size:13px;font-weight:600;color:#2E8B4F;"><svg width="16" height="16" viewBox="0 0 12 12" fill="none"><path d="M2 6.5L4.5 9L10 3" stroke="#2E8B4F" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>{{ savedMsg }}</span>
                </sc-if>
                <button onClick="{{ doSave }}" style="background: {{ saveBg }};border:none;border-radius:22px;padding:11px 30px;color:#fff;font-size:13px;font-weight:600;cursor: {{ saveCursor }};font-family:'Montserrat',sans-serif;">Save resolution</button>
              </div>
            </div>
          </div>
        </sc-if>

      </div>
    </div>
  </div>
</div>

<template id="__bundler_thumbnail" data-bg-color="#1755A1">
  <svg viewBox="0 0 1200 800" xmlns="http://www.w3.org/2000/svg">
    <rect width="1200" height="800" fill="#1755A1"/>
    <rect x="360" y="250" width="480" height="300" rx="24" fill="#ffffff"/>
    <rect x="400" y="300" width="220" height="26" rx="8" fill="#1C3A66"/>
    <rect x="400" y="350" width="400" height="14" rx="7" fill="#C9D2DD"/>
    <rect x="400" y="380" width="320" height="14" rx="7" fill="#C9D2DD"/>
    <rect x="400" y="430" width="120" height="40" rx="10" fill="#C0341F"/>
    <rect x="540" y="430" width="120" height="40" rx="10" fill="#2E8B4F"/>
    <rect x="680" y="430" width="120" height="40" rx="10" fill="#F2B200"/>
  </svg>
</template>
</x-dc>
<script type="text/x-dc" data-dc-script data-props="{
  &quot;$preview&quot;: { &quot;width&quot;: 1320, &quot;height&quot;: 940 },
  &quot;density&quot;: { &quot;editor&quot;: &quot;enum&quot;, &quot;options&quot;: [&quot;comfortable&quot;, &quot;compact&quot;], &quot;default&quot;: &quot;comfortable&quot;, &quot;tsType&quot;: &quot;string&quot; },
  &quot;defaultTab&quot;: { &quot;editor&quot;: &quot;enum&quot;, &quot;options&quot;: [&quot;Customer&quot;, &quot;AML&quot;, &quot;Resolution&quot;], &quot;default&quot;: &quot;Customer&quot;, &quot;tsType&quot;: &quot;string&quot; }
}">
class Component extends DCLogic {
  state = {
    tab: null, acctDetail: false, showAddr: false, showTels: false,
    showAml: false, docMenu: false, sbOpen: false,
    newState: '', substate: '', obs: '', saved: false
  };

  defaultTabIndex() {
    const d = this.props.defaultTab || 'Customer';
    return d === 'AML' ? 1 : d === 'Resolution' ? 2 : 0;
  }
  get activeTab() {
    return this.state.tab === null ? this.defaultTabIndex() : this.state.tab;
  }

  renderVals() {
    const t = this.activeTab;
    const bg = (i) => (i === t ? '#1C3A66' : '#2160AB');
    const ac = (i) => (i === t ? '#F2B200' : 'transparent');
    const rotOpen = (on) => (on ? 'rotate(180deg)' : 'rotate(0deg)');

    return {
      rowPad: this.props.density === 'compact' ? '7px' : '12px',

      sbOpen: this.state.sbOpen,
      sbCollapsed: !this.state.sbOpen,
      sbWidth: this.state.sbOpen ? '250px' : '58px',
      toggleSb: () => this.setState(s => ({ sbOpen: !s.sbOpen })),

      isCustomer: t === 0, isAml: t === 1, isRes: t === 2,
      tab0bg: bg(0), tab1bg: bg(1), tab2bg: bg(2),
      tab0ac: ac(0), tab1ac: ac(1), tab2ac: ac(2),
      setTab0: () => this.setState({ tab: 0 }),
      setTab1: () => this.setState({ tab: 1 }),
      setTab2: () => this.setState({ tab: 2 }),

      goBack: () => { window.location.href = 'Backoffice working tray.html#requests'; },

      docMenu: this.state.docMenu,
      toggleDoc: () => this.setState(s => ({ docMenu: !s.docMenu })),

      showAddr: this.state.showAddr,
      toggleAddr: () => this.setState(s => ({ showAddr: !s.showAddr })),
      addrRot: rotOpen(this.state.showAddr),
      addrLink: this.state.showAddr ? 'Hide other addresses' : 'Work address · Delivery address',

      showTels: this.state.showTels,
      toggleTels: () => this.setState(s => ({ showTels: !s.showTels })),
      telRot: rotOpen(this.state.showTels),
      telLink: this.state.showTels ? 'Hide other phones' : 'Tel 2 · Tel 3',

      showAml: this.state.showAml,
      toggleAml: () => this.setState(s => ({ showAml: !s.showAml })),
      amlRot: rotOpen(this.state.showAml),
      amlLink: this.state.showAml ? 'Hide full AML' : 'Show full AML (3 sources)',

      acctDetail: this.state.acctDetail,
      toggleAcct: () => this.setState(s => ({ acctDetail: !s.acctDetail })),
      acctRot: this.state.acctDetail ? 'rotate(90deg)' : 'rotate(0deg)',

      newState: this.state.newState,
      onNewState: (e) => this.setState({ newState: e.target.value, saved: false }),
      onSub: (e) => this.setState({ substate: e.target.value }),
      onObs: (e) => this.setState({ obs: e.target.value }),
      saved: this.state.saved,
      savedMsg: 'Resolution saved · ' + this.state.newState,
      saveBg: this.state.newState ? '#2E8B4F' : '#C8CCD1',
      saveCursor: this.state.newState ? 'pointer' : 'not-allowed',
      doSave: () => { if (this.state.newState) this.setState({ saved: true }); }
    };
  }
}
</script>
</body>
</html>
